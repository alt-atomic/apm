#: internal/domain/distrobox/dialog/selector.go:175
#: internal/domain/system/dialog/dialog.go:98
#: internal/domain/system/dialog/dialog.go:104
#: internal/domain/system/dialog/dialog_image.go:100
#: internal/domain/system/dialog/dialog_image.go:123
msgid "Operation cancelled"
msgstr "Операция отменена"

#: internal/common/apt/errors.go:206
msgid "Must specify at least one package to check builddeps for"
msgstr ""
"Должен быть указан хотя бы один пакет для проверки зависимостей сборки для %s"

#: internal/common/apt/errors.go:209
#, c-format
msgid "Unable to find a source package for %s"
msgstr "Невозможно найти пакет-источник для %s"

#: internal/common/apt/errors.go:212
#, c-format
msgid "Unable to get build-dependency information for %s"
msgstr "Невозможно получить информацию о зависимостях сборки для %s"

#: internal/common/apt/errors.go:215
#, c-format
msgid ""
"Some broken packages were found while trying to process build-dependencies "
"for %s"
msgstr ""
"Было найдено несколько повреждённых пакетов во время попытки вычисления "
"зависимостей сборки для %s"

#: internal/common/apt/errors.go:218
#, c-format
msgid "Package %s is a virtual package with no good providers"
msgstr "Пакет %s является виртуальным без хороших поставщиков"

