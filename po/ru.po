msgid "Internal Error, Ordering didn't finish"
msgstr "Внутренняя ошибка, заказ не был выполнен"

#: internal/common/apt/errors.go:251
msgid "Some files failed to download"
msgstr "Некоторые файлы не были скачены"

#: internal/common/apt/errors.go:254
msgid ""
"Unable to fetch some archives, maybe run apt-get update or try with --fix-"
"missing?"
msgstr ""
"Невозможно извлечь некоторые архивы, возможно стоит попробовать запустить "
"apt-get update или запустить с --fix-missing?"

#: internal/common/apt/errors.go:257
msgid "--fix-missing and media swapping is not currently supported"
msgstr "--fix-missing и смена медиа сейчас не поддерживаются"

#: internal/common/apt/errors.go:260
msgid "Unable to correct missing packages"
msgstr "Невозможно исправить отсутствующие пакеты"

#: internal/common/apt/errors.go:263
msgid "Aborting Install"
msgstr "Прервать установку"

#: internal/common/apt/errors.go:266
msgid "Could not open RPM database"
msgstr "Не удалось открыть базу данных RPM"

#: internal/common/apt/errors.go:269
#, c-format
msgid "Couldn't parse name '%s'"
msgstr "Не удалось спарсить имя '%s'"

