#: internal/common/apt/errors.go:401
#, c-format
msgid ""
"Virtual package %s has multiple providers. Please select specific package."
msgstr ""
"Виртуальный пакет %s имеет несколько поставщиков\n"
". Пожалуйста, выберите конкретный пакет."

#: internal/common/apt/errors.go:403
#, c-format
msgid "Package not found: %s"
msgstr "Пакет не найден: %s"

#: internal/common/apt/errors.go:404
#, c-format
msgid "Package is not installed: %s"
msgstr "Пакет не установлен: %s"

#: internal/common/apt/errors.go:405
#, c-format
msgid "Package %s has no installed providers"
msgstr "Пакет %s не имеет поставщиков для установки"

