#: internal/common/apt/errors.go:176
msgid "Broken packages"
msgstr "Повреждённые пакеты"

#: internal/common/apt/errors.go:179
msgid "You have no permissions for that"
msgstr "Недостаточно прав для этого"

#: internal/common/apt/errors.go:182
msgid "Internal Error, InstallPackages was called with broken packages!"
msgstr ""
"Внутренняя ошибка, InstallPackages был вызван для повреждённых пакетов!"

