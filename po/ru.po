#, c-format
msgid "Regex compilation error - %s"
msgstr "Ошибка обработки регулярного выражения - %s"

#: internal/common/apt/errors.go:284
#, c-format
msgid "Package %s has no installation candidate"
msgstr "Пакет %s не имеет кандидатов для установки"

#: internal/common/apt/errors.go:287
msgid "Internal Error, AllUpgrade broke stuff"
msgstr "Внутренняя ошибка, AllUpgrade что-то сломал"

#: internal/common/apt/errors.go:290
msgid "Requested autoremove failed."
msgstr "Требуемое автоудаление не выполнено."

#: internal/common/apt/errors.go:293
#, c-format
msgid "Couldn't find package %s"
msgstr "Не удалось найти пакет %s"

