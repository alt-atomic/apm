#, c-format
msgid "Release %s'%s' for '%s' was not found"
msgstr "Релиз %s'%s' для '%s' не найден"

#: internal/common/apt/errors.go:233
#, c-format
msgid "Version '%s' for '%s' was not found"
msgstr "Версия '%s' для пакета '%s' не найдена"

#: internal/common/apt/errors.go:236
#, c-format
msgid "Sources list %s could not be read"
msgstr "Список источников %s не может быть прочтён"

#: internal/common/apt/errors.go:239
#, c-format
msgid "Sources list %s doesn't exist"
msgstr "Списка источников %s не существует"

#: internal/common/apt/errors.go:242
msgid "Excessive arguments"
msgstr "Избыточные аргументы"

#: internal/common/apt/errors.go:245
msgid "Internal Error, problem resolver broke stuff"
msgstr "Внутренняя ошибка, средство решения проблем сломало что-то"

